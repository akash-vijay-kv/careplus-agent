OPENAI_API_KEY=sk-your-openai-api-key-here

# LLM provider: "openai" (direct) or "litellm" (proxy/direct via LiteLLM).
# The model id is shared across both providers.
LLM_PROVIDER=openai
LLM_MODEL_ID=gpt-4o-mini
# Required only when LLM_PROVIDER=litellm (both optional; LiteLLM falls back
# to its own env vars / provider defaults when unset).
LITELLM_API_KEY=
LITELLM_API_BASE=

POSTGRES_USER=careplus
POSTGRES_PASSWORD=careplus_secret
POSTGRES_DB=careplus
DATABASE_URL=postgresql+psycopg://careplus:careplus_secret@db:5432/careplus
CORS_ORIGINS=http://localhost:3000,http://frontend:3000
